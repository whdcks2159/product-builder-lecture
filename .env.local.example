# ─── NexusInsight 환경 변수 ────────────────────────────────────────────────────

# ── VAPID 키 (Web Push 알림) ──────────────────────────────────────────────────
# 생성 방법: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ 키는 브라우저 구독 시 필요, 반드시 노출됨
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# ── Push 알림 발송 API 보안 키 ────────────────────────────────────────────────
# POST /api/push/send 호출 시 Authorization: Bearer <key> 헤더에 사용
PUSH_API_KEY=your_secret_push_api_key_here

# ── 사이트 URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nexus-insight.vercel.app

# ── Google AdSense (승인 후 설정) ─────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ── AI 뉴스 요약 (Claude API) ─────────────────────────────────────────────────
# Anthropic Console에서 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXX

# /api/news/summarize 엔드포인트 보호 키 (임의 문자열 생성)
SUMMARIZE_API_KEY=your_secret_summarize_key_here

# ── Vercel Cron Job 보호 키 ───────────────────────────────────────────────────
# Vercel 대시보드 → Settings → Environment Variables에 동일한 값 설정
# Vercel이 크론 호출 시 Authorization: Bearer <CRON_SECRET> 헤더를 자동 추가
CRON_SECRET=your_secret_cron_key_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase 대시보드 → Settings → API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# 서버 전용 (절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── NewsAPI ───────────────────────────────────────────────────────────────────
# newsapi.org 무료 가입 후 발급 (개발: 하루 100건, 배포 후 Plan 업그레이드 권장)
NEWS_API_KEY=your_newsapi_key_here

# ── Gemini API ────────────────────────────────────────────────────────────────
# Google AI Studio (aistudio.google.com)에서 발급 — 무료 티어 있음
GEMINI_API_KEY=AIzaSy...
